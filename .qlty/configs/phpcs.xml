<?xml version="1.0"?>
<ruleset name="Project">

    <rule ref="SineMaculaLaravelPackage"/>

    <!--
        The repository pattern legitimately traffics in mixed: the magic
        __call/__callStatic forwarders return arbitrary builder results, and
        criteria contribute arbitrary key-value metadata. Exempt those files
        from the mixed-typehint sniff rather than scattering per-member
        suppressions through them.
    -->
    <rule ref="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint">
        <exclude-pattern>*/src/Repository.php</exclude-pattern>
        <exclude-pattern>*/src/Concerns/ManagesCriteria.php</exclude-pattern>
        <exclude-pattern>*/src/Contracts/ContributesMetadata.php</exclude-pattern>
        <exclude-pattern>*/testing/Concerns/InspectsRepository.php</exclude-pattern>
    </rule>

    <file>src</file>
    <file>testing</file>
    <file>tests</file>

</ruleset>
